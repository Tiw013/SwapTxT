<Window x:Class="TranslatorApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TranslatorApp — ตั้งค่า"
        Width="520" Height="600"
        MinWidth="480" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Drop Shadow Effect -->
    <Border CornerRadius="16" Background="#0F0F1A"
            BorderBrush="#2A2A4A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" Opacity="0.6" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>   <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="60"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="#1A1A2E"
                    MouseDown="TitleBar_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- App Icon / Mascot mini -->
                        <Border Width="36" Height="36" CornerRadius="18" Background="#252545"
                                Margin="0,0,12,0">
                            <TextBlock Text="🌸" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TranslatorApp" Foreground="White"
                                       FontFamily="Segoe UI Semibold" FontSize="15"/>
                            <TextBlock Text="ตั้งค่าโปรแกรม" Foreground="#B0B0CC"
                                       FontFamily="Segoe UI" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="MinBtn" Width="28" Height="28" Content="—"
                                Foreground="#B0B0CC" Background="Transparent"
                                BorderThickness="0" FontSize="14" Cursor="Hand"
                                Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="14" Width="28" Height="28">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#252545"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CloseBtn" Width="28" Height="28" Content="✕"
                                Foreground="#B0B0CC" Background="Transparent"
                                BorderThickness="0" FontSize="13" Cursor="Hand"
                                Margin="4,0,0,0" Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="14" Width="28" Height="28">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#CC3355"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Tab Content ── -->
            <TabControl Grid.Row="1" Style="{StaticResource ModernTabControl}"
                        x:Name="MainTabControl" Margin="16,12,16,0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
                </TabControl.ItemContainerStyle>

                <!-- ════ TAB 1: ทั่วไป ════ -->
                <TabItem Header="🏠  ทั่วไป">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4" >

                            <!-- Hotkey Section -->
                            <Border Background="#16213E" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⌨️  ปุ่มคีย์ลัด" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="14" Margin="0,0,0,12"/>

                                    <TextBlock Text="Modifier Key" Foreground="#B0B0CC"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ModifierCombo" Style="{StaticResource ModernComboBox}"
                                              Height="38" Margin="0,0,0,12">
                                        <ComboBoxItem Content="Ctrl"/>
                                        <ComboBoxItem Content="Ctrl + Shift"/>
                                        <ComboBoxItem Content="Ctrl + Alt"/>
                                        <ComboBoxItem Content="Alt"/>
                                    </ComboBox>

                                    <TextBlock Text="Key" Foreground="#B0B0CC"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="KeyCombo" Style="{StaticResource ModernComboBox}"
                                              Height="38">
                                        <ComboBoxItem Content="Space"/>
                                        <ComboBoxItem Content="Q"/>
                                        <ComboBoxItem Content="W"/>
                                        <ComboBoxItem Content="E"/>
                                        <ComboBoxItem Content="T"/>
                                        <ComboBoxItem Content="F1"/>
                                        <ComboBoxItem Content="F2"/>
                                        <ComboBoxItem Content="F9"/>
                                        <ComboBoxItem Content="F10"/>
                                        <ComboBoxItem Content="OemTilde"/>
                                    </ComboBox>

                                    <!-- Preview -->
                                    <Border Background="#0F0F1A" CornerRadius="8"
                                            Padding="12,8" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="คีย์ลัดปัจจุบัน: " Foreground="#B0B0CC"
                                                       FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="HotkeyPreviewText" Text="Ctrl + Space"
                                                       Foreground="#FF6B9D" FontFamily="Segoe UI Semibold"
                                                       FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Startup Section -->
                            <Border Background="#16213E" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🚀  การเริ่มต้นโปรแกรม" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="14" Margin="0,0,0,12"/>

                                    <CheckBox x:Name="StartupCheckBox" Content="เปิดโปรแกรมอัตโนมัติเมื่อเปิดเครื่อง"
                                              Style="{StaticResource ModernCheckBox}"/>

                                    <CheckBox x:Name="ToastCheckBox" Content="แสดงการแจ้งเตือน Toast Notification"
                                              Style="{StaticResource ModernCheckBox}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ════ TAB 2: เครื่องยนต์แปลภาษา ════ -->
                <TabItem Header="🤖  แปลภาษา">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">

                            <!-- Engine Selection -->
                            <Border Background="#16213E" CornerRadius="12" Padding="20,16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="เลือกเครื่องยนต์แปลภาษา" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="14" Margin="0,0,0,16"/>

                                    <!-- Google Translate Option -->
                                    <Border x:Name="GoogleOptionBorder" CornerRadius="10" Padding="16,14"
                                            Margin="0,0,0,8" Cursor="Hand" MouseDown="GoogleOption_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0F0F1A"/>
                                                <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <RadioButton x:Name="GoogleRadio" Grid.Column="0"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                                         GroupName="EngineGroup"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="🔍  Google Translate" Foreground="White"
                                                           FontFamily="Segoe UI Semibold" FontSize="13"/>
                                                <TextBlock Text="ฟรี ไม่ต้องการ API Key • เร็ว • แม่นยำสำหรับงานทั่วไป"
                                                           Foreground="#B0B0CC" FontFamily="Segoe UI"
                                                           FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- AI Mode Option -->
                                    <Border x:Name="AIOptionBorder" CornerRadius="10" Padding="16,14"
                                            Cursor="Hand" MouseDown="AIOption_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0F0F1A"/>
                                                <Setter Property="BorderBrush" Value="#2A2A4A"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <RadioButton x:Name="AIRadio" Grid.Column="0"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"
                                                         GroupName="EngineGroup"/>
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✨  โหมด AI" Foreground="White"
                                                               FontFamily="Segoe UI Semibold" FontSize="13"/>
                                                    <Border Background="#FF6B9D" CornerRadius="4"
                                                            Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="BYOK" Foreground="White"
                                                                   FontFamily="Segoe UI Semibold" FontSize="9"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="ต้องการ API Key • แม่นยำสูง • ปรับโทนภาษาได้"
                                                           Foreground="#B0B0CC" FontFamily="Segoe UI"
                                                           FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI Settings (shown when AI mode selected) -->
                            <Border x:Name="AISettingsPanel" Background="#16213E" CornerRadius="12"
                                    Padding="20,16" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="ตั้งค่า AI" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="14" Margin="0,0,0,12"/>

                                    <!-- Provider Selection -->
                                    <TextBlock Text="ผู้ให้บริการ" Foreground="#B0B0CC"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ProviderCombo" Style="{StaticResource ModernComboBox}"
                                              Height="38" Margin="0,0,0,12"
                                              SelectionChanged="ProviderCombo_SelectionChanged">
                                        <ComboBoxItem Content="OpenAI (GPT-4o-mini)"/>
                                        <ComboBoxItem Content="Google Gemini (Flash)"/>
                                    </ComboBox>

                                    <!-- API Key -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="ApiKeyLabel" Text="OpenAI API Key"
                                                       Foreground="#B0B0CC" FontFamily="Segoe UI"
                                                       FontSize="12" Margin="0,0,0,6"/>
                                            <PasswordBox x:Name="ApiKeyBox"
                                                         Style="{StaticResource ModernPasswordBox}"
                                                         Height="38"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="ทดสอบ" Margin="8,20,0,0"
                                                Style="{StaticResource GhostButton}"
                                                Height="38" Click="TestApiKey_Click"/>
                                    </Grid>

                                    <!-- Test Result -->
                                    <TextBlock x:Name="TestResultText" Visibility="Collapsed"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,8"
                                               TextWrapping="Wrap"/>

                                    <!-- Tone Selection -->
                                    <TextBlock Text="โทนภาษา" Foreground="#B0B0CC"
                                               FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ToneCombo" Style="{StaticResource ModernComboBox}"
                                              Height="38" Margin="0,0,0,12">
                                        <ComboBoxItem Content="มาตรฐาน"/>
                                        <ComboBoxItem Content="ทางการ"/>
                                        <ComboBoxItem Content="เป็นกันเอง"/>
                                    </ComboBox>

                                    <!-- How to get API key -->
                                    <Button x:Name="ApiHelpButton" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            Click="ApiHelp_Click">
                                        <TextBlock Foreground="#00D4FF" FontFamily="Segoe UI"
                                                   FontSize="12" TextDecorations="Underline">
                                            🔗 ทำไม่เป็น? คลิกดูวิธีขอ API Key ฟรี 1 นาที
                                        </TextBlock>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ════ TAB 3: เกี่ยวกับ ════ -->
                <TabItem Header="🌸  เกี่ยวกับ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,16,4,4">

                            <!-- Mascot Card -->
                            <Border Background="#16213E" CornerRadius="12" Padding="24,24"
                                    Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- Mascot Illustration (emoji-based) -->
                                    <Border Width="100" Height="100" CornerRadius="50"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF6B9D" Offset="0"/>
                                                <GradientStop Color="#A855F7" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="🤓" FontSize="52"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="TranslatorApp" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="20"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="VersionText" Text="v1.0.0 Demo"
                                               Foreground="#B0B0CC" FontFamily="Segoe UI"
                                               FontSize="13" HorizontalAlignment="Center"
                                               Margin="0,4,0,16"/>

                                    <TextBlock TextAlignment="Center" Foreground="#B0B0CC"
                                               FontFamily="Segoe UI" FontSize="13"
                                               TextWrapping="Wrap" Margin="0,0,0,20"
                                               LineHeight="20">
                                        <Run Text="ขอบคุณที่ใช้งานค่ะ! 💕"/>
                                        <LineBreak/>
                                        <Run Text="สนับสนุนค่าเซิร์ฟเวอร์ให้นักพัฒนาได้ที่นี่นะคะ"/>
                                    </TextBlock>

                                    <!-- Donate Button -->
                                    <Button x:Name="DonateButton" Width="200" Height="48"
                                            Click="DonateButton_Click" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="DonBd" CornerRadius="24">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FF6B9D" Offset="0"/>
                                                            <GradientStop Color="#A855F7" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="☕" FontSize="18" Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="เลี้ยงกาแฟนักพัฒนา" Foreground="White"
                                                                   FontFamily="Segoe UI Semibold" FontSize="14"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DonBd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- App Info -->
                            <Border Background="#16213E" CornerRadius="12" Padding="20,16">
                                <StackPanel>
                                    <TextBlock Text="ข้อมูลแอปพลิเคชัน" Foreground="White"
                                               FontFamily="Segoe UI Semibold" FontSize="13" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="24"/>
                                            <RowDefinition Height="24"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="เวอร์ชัน"
                                                   Foreground="#666688" FontFamily="Segoe UI" FontSize="12"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoVersion"
                                                   Text="1.0.0" Foreground="#B0B0CC"
                                                   FontFamily="Segoe UI" FontSize="12"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Framework"
                                                   Foreground="#666688" FontFamily="Segoe UI" FontSize="12"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="C# .NET 8 + WPF" Foreground="#B0B0CC"
                                                   FontFamily="Segoe UI" FontSize="12"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform"
                                                   Foreground="#666688" FontFamily="Segoe UI" FontSize="12"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="Windows 10/11" Foreground="#B0B0CC"
                                                   FontFamily="Segoe UI" FontSize="12"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="#1A1A2E" CornerRadius="0,0,16,16"
                    Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button Content="ยกเลิก" Style="{StaticResource GhostButton}"
                                Width="80" Height="36" Click="Cancel_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="💾  บันทึกตั้งค่า" Style="{StaticResource PrimaryButton}"
                                Height="36" Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
