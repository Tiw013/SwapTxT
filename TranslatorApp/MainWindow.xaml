<Window x:Class="TranslatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TranslatorApp" 
        Height="1" Width="1"
        WindowStyle="None"
        ShowInTaskbar="False"
        Visibility="Hidden"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">
    <!-- This window is intentionally invisible - it just hosts the HwndSource for hotkey registration -->
</Window>
