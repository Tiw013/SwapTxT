<Window x:Class="SwapTxT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SwapTxT — Settings"
        Width="460" Height="680"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="18" Background="#0D0D1A"
            BorderBrush="#2D2D55" BorderThickness="1"
            Margin="12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition Height="60"/>  <!-- Footer buttons -->
            </Grid.RowDefinitions>

            <!-- ── Title Bar ───────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="18,18,0,0" Background="#15152B"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Gradient icon dot -->
                        <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6C63FF" Offset="0"/>
                                    <GradientStop Color="#A78BFA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="S" Foreground="White" FontWeight="Bold" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SwapTxT" Foreground="#F0EEFF" FontSize="16"
                                       FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock Text="Translation Settings" Foreground="#8884A8"
                                       FontSize="10" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Close button -->
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="32" Height="32" Click="CloseButton_Click"
                            Background="Transparent" Foreground="#8884A8" BorderThickness="0"
                            FontSize="14" Cursor="Hand" x:Name="BtnClose"/>
                </Grid>
            </Border>

            <!-- ── Main Content ────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="1" Style="{StaticResource DarkScrollViewer}"
                          VerticalScrollBarVisibility="Auto" Padding="24,0,16,0">
                <StackPanel Margin="0,16,0,8">

                    <!-- STATUS BADGE -->
                    <Border x:Name="StatusBadge" CornerRadius="10" Padding="12,8" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D2B1A" Offset="0"/>
                                <GradientStop Color="#0A2040" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#34D399" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus" Text="Active — Ctrl+Space  •  TH→EN  •  Manual"
                                       Foreground="#34D399" FontSize="11" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ── TRANSLATION DIRECTION ────────────────────────────── -->
                    <TextBlock Text="DIRECTION" Style="{StaticResource SubHeadingStyle}" Margin="0,0,0,8"/>
                    <Border Background="#15152B" CornerRadius="12" Padding="6">
                        <UniformGrid Columns="2">
                            <RadioButton x:Name="RbEnToTh" Content="EN → TH" GroupName="Direction"
                                         Style="{StaticResource TogglePill}"
                                         Checked="Direction_Changed"
                                         ToolTip="Translate English to Thai"/>
                            <RadioButton x:Name="RbThToEn" Content="TH → EN" GroupName="Direction"
                                         Style="{StaticResource TogglePill}" IsChecked="True"
                                         Checked="Direction_Changed"
                                         ToolTip="Translate Thai to English"/>
                        </UniformGrid>
                    </Border>

                    <!-- ── TRANSLATION MODE ─────────────────────────────────── -->
                    <TextBlock Text="MODE" Style="{StaticResource SubHeadingStyle}"/>
                    <Border Background="#15152B" CornerRadius="12" Padding="6">
                        <UniformGrid Columns="2">
                            <RadioButton x:Name="RbManual" Content="✋ Manual Select" GroupName="Mode"
                                         Style="{StaticResource TogglePill}" IsChecked="True"
                                         Checked="Mode_Changed"
                                         ToolTip="Translate only the text you highlight manually"/>
                            <RadioButton x:Name="RbAuto" Content="⚡ Auto Detect" GroupName="Mode"
                                         Style="{StaticResource TogglePill}"
                                         Checked="Mode_Changed"
                                         ToolTip="Automatically find and translate the last block of text at cursor"/>
                        </UniformGrid>
                    </Border>
                    <TextBlock x:Name="TxtModeDesc"
                               Foreground="#8884A8" FontSize="11" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="4,6,0,0">
                        <Run x:Name="RunModeDesc"
                             Text="Highlight text manually, then press hotkey to translate."/>
                    </TextBlock>

                    <!-- ── HOTKEY (ComboBox style) ────────────────────────── -->
                    <TextBlock Text="HOTKEY" Style="{StaticResource SubHeadingStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Modifier ComboBox -->
                        <ComboBox Grid.Column="0" x:Name="CmbModifier"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="CmbHotkey_Changed"
                                  ToolTip="Modifier key">
                            <ComboBoxItem Content="Ctrl" Tag="Ctrl"/>
                            <ComboBoxItem Content="Alt" Tag="Alt"/>
                            <ComboBoxItem Content="Ctrl+Alt" Tag="Ctrl+Alt"/>
                            <ComboBoxItem Content="Ctrl+Shift" Tag="Ctrl+Shift"/>
                        </ComboBox>
                        <!-- Plus label -->
                        <TextBlock Grid.Column="1" Text="+" Foreground="#8884A8" FontSize="16"
                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Key ComboBox -->
                        <ComboBox Grid.Column="2" x:Name="CmbHotkeyKey"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="CmbHotkey_Changed"
                                  ToolTip="Main key">
                            <ComboBoxItem Content="Space" Tag="Space"/>
                            <ComboBoxItem Content="D" Tag="D"/>
                            <ComboBoxItem Content="E" Tag="E"/>
                            <ComboBoxItem Content="T" Tag="T"/>
                            <ComboBoxItem Content="Q" Tag="Q"/>
                            <ComboBoxItem Content="F1"  Tag="F1"/>
                            <ComboBoxItem Content="F2"  Tag="F2"/>
                            <ComboBoxItem Content="F3"  Tag="F3"/>
                            <ComboBoxItem Content="F4"  Tag="F4"/>
                            <ComboBoxItem Content="F5"  Tag="F5"/>
                            <ComboBoxItem Content="F6"  Tag="F6"/>
                            <ComboBoxItem Content="F7"  Tag="F7"/>
                            <ComboBoxItem Content="F8"  Tag="F8"/>
                            <ComboBoxItem Content="F9"  Tag="F9"/>
                            <ComboBoxItem Content="F10" Tag="F10"/>
                            <ComboBoxItem Content="F11" Tag="F11"/>
                            <ComboBoxItem Content="F12" Tag="F12"/>
                        </ComboBox>
                    </Grid>
                    <!-- Live preview -->
                    <TextBlock x:Name="TxtHotkeyPreview" Text="Hotkey: Ctrl + Space"
                               Foreground="#6C63FF" FontSize="11" FontFamily="Segoe UI"
                               FontWeight="SemiBold" Margin="2,6,0,0"/>

                    <!-- ── TRANSLATION ENGINE ───────────────────────────────── -->
                    <TextBlock Text="TRANSLATION ENGINE" Style="{StaticResource SubHeadingStyle}"/>
                    <Border Background="#15152B" CornerRadius="12" Padding="6">
                        <UniformGrid Columns="2">
                            <RadioButton x:Name="RbGoogle" Content="🌐 Google Translate" GroupName="Engine"
                                         Style="{StaticResource TogglePill}" IsChecked="True"
                                         Checked="Engine_Changed"
                                         ToolTip="Fast and free (no API key required)"/>
                            <RadioButton x:Name="RbAI" Content="🤖 Custom AI" GroupName="Engine"
                                         Style="{StaticResource TogglePill}"
                                         Checked="Engine_Changed"
                                         ToolTip="High quality translation using your own AI provider"/>
                        </UniformGrid>
                    </Border>

                    <!-- ── AI SETTINGS (shown when AI engine selected) ───────── -->
                    <StackPanel x:Name="PanelAI" Visibility="Collapsed">
                        <TextBlock Text="AI PROVIDER" Style="{StaticResource SubHeadingStyle}"/>
                        <ComboBox x:Name="CmbProvider" Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="CmbProvider_SelectionChanged">
                            <ComboBoxItem Content="OpenRouter" Tag="OpenRouter"/>
                            <ComboBoxItem Content="OpenAI" Tag="OpenAI"/>
                            <ComboBoxItem Content="Google Gemini" Tag="Gemini"/>
                        </ComboBox>

                        <TextBlock Text="API KEY" Style="{StaticResource SubHeadingStyle}"/>
                        <TextBox x:Name="TxtApiKey" Style="{StaticResource DarkTextBox}"
                                 FontFamily="Consolas" FontSize="12"
                                 TextChanged="TxtApiKey_TextChanged"/>

                        <!-- OpenRouter model selector -->
                        <StackPanel x:Name="PanelModel">
                            <TextBlock Text="MODEL" Style="{StaticResource SubHeadingStyle}"/>
                            <ComboBox x:Name="CmbModel" Style="{StaticResource DarkEditableComboBox}"
                                      IsEditable="True"
                                      ToolTip="Select or type your custom model name"
                                      TextBoxBase.TextChanged="HybridComboBox_TextChanged"
                                      SelectionChanged="HybridComboBox_SelectionChanged">
                            </ComboBox>
                        </StackPanel>

                        <!-- Tone selector -->
                        <StackPanel x:Name="PanelTone">
                            <TextBlock Text="MOOD &amp; TONE" Style="{StaticResource SubHeadingStyle}"/>
                            <ComboBox x:Name="CmbTone" Style="{StaticResource DarkEditableComboBox}"
                                      IsEditable="True"
                                      ToolTip="Choose a translation tone, or type your own!"
                                      TextBoxBase.TextChanged="HybridComboBox_TextChanged"
                                      SelectionChanged="HybridComboBox_SelectionChanged">
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── PREFERENCES ───────────────────────────────────── -->
                    <TextBlock Text="PREFERENCES" Style="{StaticResource SubHeadingStyle}"/>
                    <Border Background="#15152B" CornerRadius="12" Padding="16,12">
                        <StackPanel>
                            <!-- Notifications toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🔔  Show Notifications" Foreground="#F0EEFF"
                                               FontFamily="Segoe UI" FontSize="13"/>
                                    <TextBlock Text="Show success/error toasts after each translation"
                                               Foreground="#8884A8" FontSize="11" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkNotifications" Grid.Column="1"
                                          VerticalAlignment="Center" IsChecked="True"
                                          Checked="ChkNotifications_Changed" Unchecked="ChkNotifications_Changed"/>
                            </Grid>
                            <!-- Divider -->
                            <Border Height="1" Background="#2D2D55" Margin="0,10,0,10"/>
                            <!-- Run on Startup toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🚀  Run on Startup" Foreground="#F0EEFF"
                                               FontFamily="Segoe UI" FontSize="13"/>
                                    <TextBlock Text="Launch SwapTxT automatically when Windows starts"
                                               Foreground="#8884A8" FontSize="11" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkStartup" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Checked="ChkStartup_Changed" Unchecked="ChkStartup_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── ABOUT / COFFEE CARD ──────────────────────────── -->
                    <Border Background="#0E0E22" CornerRadius="12"
                            BorderBrush="#2D2D55" BorderThickness="1"
                            Margin="0,8,0,4" Padding="14,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: app name + dev label -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SwapTxT" Foreground="#A78BFA"
                                               FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text=" v1.0.0" Foreground="#44445A"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="Made by TIXS" Foreground="#44445A"
                                           FontFamily="Segoe UI" FontSize="10" Margin="0,1,0,0"/>
                            </StackPanel>

                            <!-- About button -->
                            <Border Grid.Column="2" CornerRadius="8" Padding="10,6"
                                    Cursor="Hand" MouseLeftButtonUp="AboutBtn_Click">
                                <Border.Background>
                                    <SolidColorBrush Color="#2D2D55"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ℹ️" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" About" FontSize="11" Foreground="#FFFFFF"
                                               FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Donate button -->
                            <Border Grid.Column="4" CornerRadius="8" Padding="10,6"
                                    Cursor="Hand" MouseLeftButtonUp="CoffeeBtn_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4A2A00" Offset="0"/>
                                        <GradientStop Color="#703A00" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💖" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Support Dev" FontSize="11" Foreground="#FFFFFF"
                                               FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer Buttons ──────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#15152B" CornerRadius="0,0,18,18"
                    BorderBrush="#2D2D55" BorderThickness="0,1,0,0">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtSaveStatus" Grid.Column="0" Text=""
                               Foreground="#34D399" FontSize="11" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click" Height="38" Padding="20,0"/>
                    <Button Grid.Column="3" Content="Save Settings" Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click" Height="38"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

